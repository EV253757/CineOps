{
  "navigationFallback": { "rewrite": "/index.html" },
  "routes": [
    { "route": "/login", "rewrite": "/.auth/login/aad" },
    { "route": "/api/*", "allowedRoles": ["authenticated"] },
    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "statusCode": 302, "redirect": "/.auth/login/aad" }
  }
}
